# length of record to download (seconds)
WINDOW_SECONDS=3600

# start time UTC (leave blank or commented to download seismograms up to current time)
# examples below will download seismograms from named earthquakes
# CALENDAR_TIME_START=2010-09-03T16:20:00 # 2010 M 7.1 Darfield, New Zealand
CALENDAR_TIME_START=2025-07-29T23:20:00 # 2025 M 8.8 Kamchatka
CALENDAR_TIME_START=2026-06-24T22:00:00 # 2026 M 7.2, M 7.5 Venezuela, M 6.9 Japan

# list of seismic stations (STNM|NET|LOC)
# global stations
*station_start*
BAK|CI|--
MBWA|IU|00
