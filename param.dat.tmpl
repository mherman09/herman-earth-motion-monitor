*station_end*

#*station_start*
#BAK|CI|--
#*station_end*

# bandpass filter corner frequencies (hz)
HP_FILTER_CORNER_FREQ=0.125
LP_FILTER_CORNER_FREQ=1.25

# minimum significance for plotting earthquakes on waveforms and map
# https://earthquake.usgs.gov/earthquakes/browse/significant.php#sigdef
MINSIG=500
